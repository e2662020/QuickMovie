generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ User System ============
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teamMemberships TeamMember[]
  ownedTeams      Team[]
  createdBoards   DirectorBoard[]
  comments        Comment[]
  sessions        UserSession[]
}

// ============ Team System ============
model Team {
  id                 String   @id @default(cuid())
  name               String
  icon               String?
  inviteCode         String   @unique
  ownerId            String
  aiApiKey           String?
  aiEndpoint         String?
  aiModel            String?
  webSearchEndpoint  String?
  webSearchApiKey    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  owner   User          @relation(fields: [ownerId], references: [id])
  members TeamMember[]
  boards  DirectorBoard[]

  @@index([inviteCode])
  @@index([ownerId])
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
}

// ============ Director Board ============
model DirectorBoard {
  id        String   @id @default(cuid())
  name      String
  teamId    String
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team         Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  creator      User          @relation(fields: [createdBy], references: [id])
  files        BoardFile[]
  resources    Resource[]
  storyElements StoryElement[]

  @@index([teamId])
  @@index([createdBy])
}

// ============ Board Files ============
model BoardFile {
  id        String   @id @default(cuid())
  boardId   String
  parentId  String?
  name      String
  type      String   // planning, storyboard, script, storyboard_shot, word, excel, note, folder
  content   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board    DirectorBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  parent   BoardFile?    @relation("FileTree", fields: [parentId], references: [id], onDelete: Cascade)
  children BoardFile[]   @relation("FileTree")
  resources Resource[]
  comments  Comment[]
  storyElements StoryElement[]

  @@index([boardId])
  @@index([parentId])
}

// ============ Resource Library ============
model Resource {
  id          String   @id @default(cuid())
  boardId     String
  fileId      String?
  name        String
  type        String
  url         String
  originalUrl String?
  size        Int?
  mimeType    String?
  createdAt   DateTime @default(now())

  board DirectorBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  file  BoardFile?    @relation(fields: [fileId], references: [id], onDelete: SetNull)

  @@index([boardId])
  @@index([fileId])
}

// ============ Story Board Elements ============
model StoryElement {
  id        String   @id @default(cuid())
  boardId   String
  fileId    String?
  type      String   // mind_map, story_segment, character, scene
  name      String
  content   String?
  color     String?
  position  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  board    DirectorBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  file     BoardFile?    @relation(fields: [fileId], references: [id], onDelete: SetNull)
  comments Comment[]

  @@index([boardId])
  @@index([type])
}

// ============ Comments ============
model Comment {
  id        String   @id @default(cuid())
  userId    String
  fileId    String?
  elementId String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  file    BoardFile?    @relation(fields: [fileId], references: [id], onDelete: Cascade)
  element StoryElement? @relation(fields: [elementId], references: [id], onDelete: Cascade)
}

// ============ Session ============
model UserSession {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}
