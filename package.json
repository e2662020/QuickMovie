{
  "name": "quickmovie",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:client": "vite --mode development.client",
    "build": "tsc -b && vite build && node scripts/build-check.js",
    "build:tauri": "tsc -b && vite build --mode tauri && node scripts/build-check.js",
    "build:check": "node scripts/build-check.js",
    "preview": "vite preview",
    "lint": "eslint src",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "node scripts/build-check.js --production && tauri build",
    "tauri:build:windows": "node scripts/build-check.js --production && tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:linux": "node scripts/build-check.js --production && tauri build --target x86_64-unknown-linux-gnu",
    "tauri:build:mac": "node scripts/build-check.js --production && tauri build --target universal-apple-darwin",
    "tauri:android:init": "tauri android init",
    "tauri:android:dev": "tauri android dev",
    "tauri:android:build": "tauri android build",
    "server:dev": "cd server && npm run dev",
    "server:build": "cd server && npm run build"
  },
  "dependencies": {
